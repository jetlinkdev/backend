# Jetlink Backend Environment Variables
# Copy this file to .env and update with your actual values

# ===========================================
# Server Configuration
# ===========================================
SERVER_ADDR=:8080

# ===========================================
# Database Configuration (MySQL)
# ===========================================
# MySQL DSN (Data Source Name)
# Format: username:password@tcp(host:port)/dbname?params
MYSQL_DSN=ferdifir:WsQ4g|1N4"56@tcp(localhost:3306)/jetlink?charset=utf8mb4&parseTime=True&loc=Local

# MySQL individual config (alternative to DSN)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=jetlink

# ===========================================
# Redis Configuration
# ===========================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# Environment
# ===========================================
ENV=development
